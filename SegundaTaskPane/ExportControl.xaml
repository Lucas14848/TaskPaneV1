<UserControl x:Class="SegundaTaskPane.ExportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="300">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BgColor" Color="#121212"/>
        <SolidColorBrush x:Key="CardColor" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="MainColor" Color="#00B4FF"/>
        <SolidColorBrush x:Key="BtnBg" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="BtnText" Color="#EEE"/>
        <SolidColorBrush x:Key="BorderColor" Color="#333"/>

        <Style x:Key="EditValueStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource MainColor}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <EventSetter Event="LostFocus" Handler="TextBox_LostFocus"/>
            <EventSetter Event="TextChanged" Handler="TextBox_TextChanged"/>
            <EventSetter Event="GotKeyboardFocus" Handler="TextBox_GotKeyboardFocus"/>
            <EventSetter Event="PreviewMouseDown" Handler="TextBox_PreviewMouseDown"/>
        </Style>

        <Style x:Key="MacroButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="{DynamicResource BtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource BtnText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="icon" Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="6,0,10,0" Foreground="{DynamicResource MainColor}"/>
                                <ContentPresenter x:Name="content" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource MainColor}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{DynamicResource BtnBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BtnBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,15,10,15">

                <Border x:Name="PropriedadesBorder" Background="{DynamicResource CardColor}" CornerRadius="6" 
                        Padding="10" Margin="0,0,0,15" BorderBrush="{DynamicResource BorderColor}" 
                        BorderThickness="1" Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Nome Proj." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                            <TextBox x:Name="TxtNomProjeto" Style="{StaticResource EditValueStyle}" Tag="Nom.Projeto"/>
                        </DockPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Cód. Proj." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                            <TextBox x:Name="TxtCodProjeto" Style="{StaticResource EditValueStyle}" Tag="Conjunto"/>
                        </DockPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Denom." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                            <TextBox x:Name="TxtDenominacao" Style="{StaticResource EditValueStyle}" Tag="Denominação"/>
                        </DockPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Nº Des." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                            <TextBox x:Name="TxtNumeroDesenho" Style="{StaticResource EditValueStyle}" Tag="Número Desenho"/>
                        </DockPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Cód. Sist." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                            <TextBox x:Name="TxtCodigo" Style="{StaticResource EditValueStyle}" Tag="Código"/>
                        </DockPanel>
                        <DockPanel Margin="0,2">
                            <TextBlock Text="Rev." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                            <TextBox x:Name="TxtRevisao" Style="{StaticResource EditValueStyle}" Tag="Rev."/>
                        </DockPanel>

                        <Button x:Name="BtnExpandir" Content="▼ MAIS DETALHES" Margin="0,8,0,0" Height="22" Background="Transparent" Foreground="{DynamicResource MainColor}" FontSize="10" BorderThickness="0" Click="BtnExpandir_Click"/>

                        <StackPanel x:Name="GridExpandido" Visibility="Collapsed" Margin="0,5,0,0">
                            <Separator Background="{DynamicResource BorderColor}" Margin="0,5,0,10"/>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="Projetista" FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtProjetista" Style="{StaticResource EditValueStyle}" Tag="Projetista"/>
                            </DockPanel>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Data Proj." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtDataProjeto" Style="{StaticResource EditValueStyle}" Tag="Data do Projeto"/>
                            </DockPanel>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Aprovador" FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtAprov" Style="{StaticResource EditValueStyle}" Tag="Aprov."/>
                            </DockPanel>
                            <DockPanel Margin="0,2">
                                <TextBlock Text="Data Apr." FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtDatAprov" Style="{StaticResource EditValueStyle}" Tag="Dat.Aprov."/>
                            </DockPanel>

                            <DockPanel x:Name="RowMaterial" Margin="0,2">
                                <TextBlock Text="Material" FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtMaterial" Style="{StaticResource EditValueStyle}" Tag="Material"/>
                            </DockPanel>
                            <DockPanel x:Name="RowEspessura" Margin="0,2">
                                <TextBlock Text="Espessura" FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtEspessura" Style="{StaticResource EditValueStyle}" Tag="Espessura"/>
                            </DockPanel>
                            <DockPanel x:Name="RowCatalogo" Margin="0,2">
                                <TextBlock Text="Catálogo" FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtCatalogo" Style="{StaticResource EditValueStyle}" Tag="Catálogo"/>
                            </DockPanel>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="Peso (kg)" FontSize="11" Foreground="{DynamicResource MainColor}"/>
                                <TextBox x:Name="TxtPeso" Style="{StaticResource EditValueStyle}" IsReadOnly="True" Opacity="0.6"/>
                            </DockPanel>

                            <StackPanel Margin="0,5,0,0">
                                <TextBlock Text="Observação:" FontSize="11" Foreground="{DynamicResource MainColor}" Margin="0,0,0,4"/>
                                <TextBox x:Name="TxtObs" Style="{StaticResource EditValueStyle}" Tag="Obs." TextAlignment="Left" TextWrapping="Wrap" AcceptsReturn="True" Height="Auto" MinHeight="40"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="LblTituloMacros" Text="MACROS" Foreground="{DynamicResource MainColor}" FontWeight="Bold" Margin="2,5,0,8" FontSize="10"/>

                <StackPanel x:Name="PanelMacrosMontagem" Visibility="Collapsed">
                    <Button Content="01 - CRIAR 3 VISTAS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro01_Click"/>
                    <Button Content="03 - REVISÕES E CÓPIAS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro03_Click"/>
                    <Button Content="04 - SALVA PDFs ERP" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro04_Click"/>
                    <Button Content="06 - SOLDAGEM 3D" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro06_Click"/>
                    <Button Content="07 - LISTA CHAPAS DXF" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro07_Click"/>
                    <Button Content="14 - NAV. CATÁLOGOS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro14_Click"/>
                    <Button Content="15 - ESPESSURA CHAPA" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro15_Click"/>
                    <Button Content="16 - CORES CHAPA" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro16_Click"/>
                    <Button Content="17 - CAVIDADE ALIVIO" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro17_Click"/>
                    <Button Content="18 - IMPORTA CIGAM" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro18_Click"/>
                    <Button Content="22 - MANGUEIRAS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro22_Click"/>
                    <Button Content="25 - VERIFICA REVISÕES" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro25_Click"/>
                    <Button Content="26 - PACOTE PROPRIEDADES" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro26_Click"/>
                    <Button Content="40 - PÓS IMPORTADOR" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro40_Click"/>
                    <Button Content="41 - REVISÃO WORD" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro41_Click"/>
                    <Button Content="50 - CATÁLOGO PEÇAS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro50_Click"/>
                    <Button Content="55 - CADASTRA SELECAO" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro55_Click"/>
                </StackPanel>

                <StackPanel x:Name="PanelMacrosPeca" Visibility="Collapsed">
                    <Button Content="01 - CRIAR 3 VISTAS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro01_Click"/>
                    <Button Content="03 - REVISÕES E CÓPIAS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro03_Click"/>
                    <Button Content="07 - LISTA CHAPAS DXF" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro07_Click"/>
                    <Button Content="15 - ESPESSURA CHAPA" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro15_Click"/>
                    <Button Content="17 - CAVIDADE ALIVIO" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro17_Click"/>
                    <Button Content="26 - PACOTE PROPRIEDADES" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro26_Click"/>
                    <Button Content="41 - REVISÃO WORD" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro41_Click"/>
                </StackPanel>

                <StackPanel x:Name="PanelMacrosDesenho" Visibility="Collapsed">
                    <Button Content="02 - RENUMERAR FOLHAS" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro02_Click"/>
                    <Button Content="04 - SALVA PDFs ERP" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro04_Click"/>
                    <Button Content="05 - IMPRESSÃO AUTO" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro05_Click"/>
                    <Button Content="13 - SALVA PDF CIGAM" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro13_Click"/>
                    <Button Content="24 - LINK VISTAS BOM" Style="{StaticResource MacroButtonStyle}" Click="BtnMacro24_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource CardColor}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0" Padding="5">
            <StackPanel Orientation="Vertical">
                <Button x:Name="BtnSalvarProps" Content="SALVAR AGORA" Height="22" Width="110" HorizontalAlignment="Left"
                        Background="{DynamicResource BtnBg}" Foreground="{DynamicResource MainColor}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                        FontWeight="Bold" FontSize="9" Margin="0,0,0,4" Click="BtnSalvarProps_Click" Cursor="Hand"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" >
                    <Button x:Name="BtnAtualizarProps" Content="ATUALIZAR PROPS" Height="30" Width="Auto" Margin="0,0,5,0"
                            Background="{DynamicResource BtnBg}" Foreground="{DynamicResource MainColor}"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                            FontWeight="Bold" FontSize="11" Click="BtnAtualizarProps_Click" Cursor="Hand"/>

                    <Button x:Name="BtnTheme" Content="ALTERAR TEMA ◐" Height="30" Width="Auto"
                            Background="{DynamicResource BtnBg}" Foreground="{DynamicResource MainColor}" 
                            BorderThickness="1" BorderBrush="{DynamicResource BorderColor}"
                            FontWeight="Bold" FontSize="11" Click="BtnTheme_Click" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
